@page "/"

<PageTitle>Azure Portal Analyzer</PageTitle>

<div class="hero-section bg-primary text-white py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold">Azure Portal Analyzer</h1>
                <p class="lead">Analyze your Azure infrastructure, get detailed reports, and receive actionable recommendations via email.</p>
                <div class="mt-4">
                    <a href="/analysis" class="btn btn-light btn-lg me-3">
                        <i class="bi bi-play-circle"></i> Start Analysis
                    </a>
                    <a href="#features" class="btn btn-outline-light btn-lg">
                        <i class="bi bi-info-circle"></i> Learn More
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <i class="bi bi-azure display-1"></i>
            </div>
        </div>
    </div>
</div>

<div class="container my-5" id="features">
    <div class="row">
        <div class="col-lg-12 text-center mb-5">
            <h2>Key Features</h2>
            <p class="lead">Comprehensive Azure infrastructure analysis and reporting</p>
        </div>
    </div>
    
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 text-center">
                <div class="card-body">
                    <i class="bi bi-search display-4 text-primary mb-3"></i>
                    <h5 class="card-title">Resource Discovery</h5>
                    <p class="card-text">Automatically discover and catalog all your Azure resources across subscriptions and resource groups.</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100 text-center">
                <div class="card-body">
                    <i class="bi bi-file-earmark-pdf display-4 text-primary mb-3"></i>
                    <h5 class="card-title">Detailed Reports</h5>
                    <p class="card-text">Generate comprehensive PDF reports with resource details, cost analysis, and optimization recommendations.</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100 text-center">
                <div class="card-body">
                    <i class="bi bi-envelope display-4 text-primary mb-3"></i>
                    <h5 class="card-title">Email Delivery</h5>
                    <p class="card-text">Receive your analysis reports directly in your inbox with detailed summaries and download links.</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100 text-center">
                <div class="card-body">
                    <i class="bi bi-graph-up display-4 text-success mb-3"></i>
                    <h5 class="card-title">Cost Optimization</h5>
                    <p class="card-text">Get actionable recommendations to optimize your Azure spending and improve resource utilization.</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100 text-center">
                <div class="card-body">
                    <i class="bi bi-shield-check display-4 text-success mb-3"></i>
                    <h5 class="card-title">Security Insights</h5>
                    <p class="card-text">Identify security best practices and compliance recommendations for your Azure infrastructure.</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100 text-center">
                <div class="card-body">
                    <i class="bi bi-clock-history display-4 text-info mb-3"></i>
                    <h5 class="card-title">Real-time Status</h5>
                    <p class="card-text">Track analysis progress in real-time with live status updates and automatic refresh capabilities.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-light py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <h3>Ready to analyze your Azure infrastructure?</h3>
                <p class="lead">Get started with a comprehensive analysis of your Azure resources in just a few clicks.</p>
                <a href="/analysis" class="btn btn-primary btn-lg">
                    <i class="bi bi-rocket"></i> Start Your Analysis Now
                </a>
            </div>
        </div>
    </div>
</div>
