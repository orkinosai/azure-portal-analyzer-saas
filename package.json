{
  "name": "azure-portal-analyzer-saas",
  "version": "1.0.0",
  "description": "SaaS application for Azure Portal analysis with secure document downloads",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "npm run build:client",
    "build:client": "cd client && npm run build",
    "test": "jest",
    "lint": "eslint server/ client/src/",
    "install:all": "npm install && cd client && npm install"
  },
  "keywords": ["azure", "portal", "analyzer", "saas", "documentation"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "sqlite3": "^5.1.6",
    "jspdf": "^2.5.1",
    "markdown-pdf": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0"
  }
}