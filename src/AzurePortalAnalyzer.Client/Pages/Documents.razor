@page "/documents"
@using System.Net.Http.Json
@using System.Text.Json
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<PageTitle>Document Management</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h3>Azure Portal Analysis Documents</h3>
            <p class="text-muted">Generate and download secure analysis reports for your Azure Portal</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Create New Document</h5>
                </div>
                <div class="card-body">
                    <form @onsubmit="CreateDocument" @onsubmit:preventDefault="true">
                        <div class="mb-3">
                            <label for="title" class="form-label">Document Title</label>
                            <input type="text" class="form-control" id="title" @bind="newDocumentTitle" required>
                        </div>
                        <div class="mb-3">
                            <label for="type" class="form-label">Document Type</label>
                            <select class="form-select" id="type" @bind="newDocumentType">
                                <option value="0">Portal Analysis Report</option>
                                <option value="1">Compliance Report</option>
                                <option value="2">Security Audit</option>
                                <option value="3">Custom Report</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary" disabled="@isCreating">
                            @if (isCreating)
                            {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                <span>Creating...</span>
                            }
                            else
                            {
                                <span>Create Document</span>
                            }
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Your Documents</h5>
                </div>
                <div class="card-body">
                    @if (documents == null)
                    {
                        <div class="text-center">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    }
                    else if (!documents.Any())
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i>
                            No documents found. Create your first document to get started.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Type</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var doc in documents)
                                    {
                                        <tr>
                                            <td>@doc.Title</td>
                                            <td>@GetDocumentTypeString(doc.Type)</td>
                                            <td>
                                                <span class="badge @GetStatusBadgeClass(doc.Status)">
                                                    @GetStatusString(doc.Status)
                                                </span>
                                            </td>
                                            <td>@doc.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                @if (doc.Status == 2) // Generated
                                                {
                                                    <button class="btn btn-sm btn-success" @onclick="() => DownloadDocument(doc.Id)">
                                                        <i class="bi bi-download"></i> Download
                                                    </button>
                                                }
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteDocument(doc.Id)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div class="toast show" role="alert">
            <div class="toast-header">
                <strong class="me-auto">Notification</strong>
                <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
            </div>
            <div class="toast-body">
                @message
            </div>
        </div>
    </div>
}

@code {
    private List<DocumentDto>? documents;
    private string newDocumentTitle = string.Empty;
    private int newDocumentType = 0;
    private bool isCreating = false;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDocuments();
    }

    private async Task LoadDocuments()
    {
        try
        {
            // For demo purposes, we'll show mock data since we don't have authentication set up
            documents = new List<DocumentDto>
            {
                new DocumentDto
                {
                    Id = 1,
                    Title = "Azure Portal Security Analysis",
                    Type = 0,
                    Status = 2,
                    CreatedAt = DateTime.Now.AddDays(-1),
                    UserId = "demo"
                },
                new DocumentDto
                {
                    Id = 2,
                    Title = "Compliance Report Q4 2024",
                    Type = 1,
                    Status = 1,
                    CreatedAt = DateTime.Now.AddHours(-2),
                    UserId = "demo"
                }
            };
        }
        catch (Exception ex)
        {
            message = $"Error loading documents: {ex.Message}";
        }
    }

    private async Task CreateDocument()
    {
        if (string.IsNullOrWhiteSpace(newDocumentTitle))
        {
            message = "Please enter a document title.";
            return;
        }

        isCreating = true;
        try
        {
            // For demo purposes, simulate document creation
            await Task.Delay(2000);
            
            var newDoc = new DocumentDto
            {
                Id = documents?.Count + 1 ?? 1,
                Title = newDocumentTitle,
                Type = newDocumentType,
                Status = 1, // Processing
                CreatedAt = DateTime.Now,
                UserId = "demo"
            };

            documents?.Add(newDoc);
            newDocumentTitle = string.Empty;
            message = "Document creation started. It will be ready for download shortly.";

            // Simulate processing completion
            _ = Task.Run(async () =>
            {
                await Task.Delay(5000);
                newDoc.Status = 2; // Generated
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            message = $"Error creating document: {ex.Message}";
        }
        finally
        {
            isCreating = false;
        }
    }

    private async Task DownloadDocument(int documentId)
    {
        try
        {
            message = "Generating secure download link...";
            
            // For demo purposes, simulate download URL generation
            await Task.Delay(1000);
            
            var downloadUrl = $"https://example.blob.core.windows.net/documents/sample-document-{documentId}.pdf?sv=2023-01-03&st=2024-01-01T00%3A00%3A00Z&se=2024-01-01T01%3A00%3A00Z&sr=b&sp=r&sig=SampleSignature";
            
            await JSRuntime.InvokeVoidAsync("open", downloadUrl, "_blank");
            message = "Secure download link generated successfully!";
        }
        catch (Exception ex)
        {
            message = $"Error generating download link: {ex.Message}";
        }
    }

    private async Task DeleteDocument(int documentId)
    {
        try
        {
            var docToDelete = documents?.FirstOrDefault(d => d.Id == documentId);
            if (docToDelete != null)
            {
                documents?.Remove(docToDelete);
                message = "Document deleted successfully.";
            }
        }
        catch (Exception ex)
        {
            message = $"Error deleting document: {ex.Message}";
        }
    }

    private string GetDocumentTypeString(int type)
    {
        return type switch
        {
            0 => "Portal Analysis Report",
            1 => "Compliance Report",
            2 => "Security Audit",
            3 => "Custom Report",
            _ => "Unknown"
        };
    }

    private string GetStatusString(int status)
    {
        return status switch
        {
            0 => "Draft",
            1 => "Processing",
            2 => "Generated",
            3 => "Failed",
            4 => "Archived",
            _ => "Unknown"
        };
    }

    private string GetStatusBadgeClass(int status)
    {
        return status switch
        {
            0 => "bg-secondary",
            1 => "bg-warning",
            2 => "bg-success",
            3 => "bg-danger",
            4 => "bg-dark",
            _ => "bg-secondary"
        };
    }

    public class DocumentDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string FileName { get; set; } = string.Empty;
        public string BlobName { get; set; } = string.Empty;
        public string ContentType { get; set; } = string.Empty;
        public long Size { get; set; }
        public string UserId { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public DateTime UpdatedAt { get; set; }
        public int Status { get; set; }
        public int Type { get; set; }
    }
}